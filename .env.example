# Server connection
MC_HOST=localhost
MC_PORT=25565
MC_USERNAME=bot@example.com
MC_PASSWORD=
MC_VERSION=auto
MC_ONLINE_MODE=false

# Bot settings
NUM_BOTS=1
BOT_PREFIX=SmartBot
MASTER_USERNAME=player

# LLM settings
LLM_PROVIDER=ollama
OLLAMA_HOST=http://localhost:11434
LLM_MODEL=llama3.1:8b
LLM_TEMPERATURE=0.3

# Memory
MEMORY_DIR=./training_data
USE_EMBEDDINGS=true

# HTTP control API
HTTP_API_PORT=8787