sudo apt-get install -y nodejs | cat
node -v
npm -v

# Если проект не в /workspace, клонируйте свой репозиторий ниже
# git clone https://github.com/USER/REPO.git && cd REPO
cd /workspace || true
npm install | cat# Smart Minecraft Bots — Colab Setup

