# Smart Minecraft Bots — Colab Setup

Настройка окружения, Ollama и запуск ботов.

- Шаг 1: Установка Node.js и зависимостей
- Шаг 2: (Опционально) Установка Ollama и моделей
- Шаг 3: Монтирование Google Drive
- Шаг 4: Запуск ботов#@title Шаг 4 — Запуск ботов
import os, subprocess

# Параметры (можно менять через переменные окружения у ячейки)
env = os.environ.copy()
env['GOOGLE_COLAB'] = '1'
env.setdefault('MC_HOST', 'localhost')
env.setdefault('MC_PORT', '25565')
env.setdefault('NUM_BOTS', '1')
env.setdefault('LLM_PROVIDER', 'ollama')
env.setdefault('OLLAMA_HOST', 'http://localhost:11434')
env.setdefault('LLM_MODEL', 'llama3.1:8b')

workdir = '/content/smart-minecraft-bots' if os.path.exists('/content/smart-minecraft-bots') else '/content'
node_path = os.path.join(workdir, 'src', 'index.js') if os.path.exists(os.path.join(workdir, 'src', 'index.js')) else '/workspace/src/index.js'

proc = subprocess.Popen(['node', node_path], cwd=workdir if os.path.exists(node_path) else '/workspace', env=env, stdout=subprocess.PIPE, stderr=subprocess.STDOUT, text=True)
for line in proc.stdout:
  print(line, end='')#@title Шаг 3 — Монтирование Google Drive (для памяти)
from google.colab import drive
try:
  drive.mount('/content/drive')
  print('Drive mounted at /content/drive')
except Exception as e:
  print('Drive mount skipped or failed:', e)#@title Шаг 2 — (Опционально) Установка и запуск Ollama + моделей
%%shell
set -e
if [ "${INSTALL_OLLAMA:-1}" = "1" ]; then
  curl -fsSL https://ollama.com/install.sh | sh | cat || true
  nohup ollama serve > /content/ollama.log 2>&1 &
  sleep 3
  echo "Pulling models..."
  ollama pull llama3.1:8b | cat || true
  ollama pull nomic-embed-text | cat || true
  echo "Ollama ready."
else
  echo "Skipping Ollama installation."
fi#@title Шаг 1 — Установка Node.js и зависимостей
%%shell
set -e
sudo apt-get update -y | cat
sudo apt-get install -y curl git | cat

# Node 18+
curl -fsSL https://deb.nodesource.com/setup_18.x | sudo -E bash - | cat
sudo apt-get install -y nodejs | cat
node -v
npm -v

# Если проект в другом репозитории, установите REPO_URL в переменных окружения
# Например: REPO_URL=https://github.com/USER/REPO.git
WORKDIR=/content
if [ -n "${REPO_URL:-}" ]; then
  cd /content
  git clone "$REPO_URL" smart-minecraft-bots | cat
  WORKDIR=/content/smart-minecraft-bots
fi

cd "$WORKDIR" || true
npm install | cat# Smart Minecraft Bots — Colab Setup

